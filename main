//define the main method

//created the scanner object input
Scanner input = new Scanner(System.in);

//declare and initialize the two one-dimensional arrays
String[] names = new String[50];
double[] grades = new double[50];

//declare and initialize count variable for amount of elements in each array
int count = 0;

//create menu method

//menu options
//1. Add Student and grade(method)
    public static void updateArrays(double[] grades, String[] names, int count, Scanner input) {

    //ask user for name and grade input
    //store input into name and grade arrays
        System.out.println("Enter student name: ");
        names[count] = input.nextLine();
        System.out.println("Enter student grade: ");
        grades[count] = input.nextDouble();

        input.nextLine();  //consume leftover newline so nextLine() works properly
    
    }

//2. Display all students and grades(method)
//isaac
    public static void printArrays(double[] grades, String[] names, int count) {
        for (int i=0;i<count;i++) {    //loops through arrays and stops at the amount of elements added
            System.out.println("Name: " + names[i] + "\nGrade: " + grades[i]);   //prints the name and subsequent grade at each position
            System.out.println();   //space for cleaner formatting 
        }  
    }

//3. Find a student's grade(method)
//kani

// args Scanner input used to read user input
// args names array storing student names
// args grades array storing student grades (matched by index with names)
// args count number of students currently stored in the arrays
public static void findStudentGrade(Scanner input, String[] names, int[] grades, int count){
  // Ask user for the student name they want to find
  System.out.print("Enter student name: "); 
  String name = input.nextLine(); 

  // flag to track if the student is found
  boolean found = false; 

  // loop through all stored students 
  for(int i = 0; i < count; i++){
    // Check if current name matches the input name
    if(names[i].equals(name)){
    System.out.print(names[i] + "'s " + " Grade: " + grades[i]);
    // Mark as found
    found = true;
    // Stop searching once found
    break; 
    }
  }
  // If no match was found, display message
  if(!found){
    System.out.println("Student not found.");
  } 
}
//4. Calculate class average(method)

//5. Find highest and lowest grades.(method)
public static void findHighestAndLowest(String[] names, int[] grades, int count) {
    if (count == 0) {
        System.out.println("No student data available.");
        return;
    }

    int max = grades[0];
    int min = grades[0];
    int maxIndex = 0;
    int minIndex = 0;

    for (int i = 1; i < count; i++) {
        if (grades[i] > max) {
            max = grades[i];
            maxIndex = i;
        }
        if (grades[i] < min) {
            min = grades[i];
            minIndex = i;
        }
    }

    System.out.println("Highest Grade: " + names[maxIndex] + " - " + max);
    System.out.println("Lowest Grade: " + names[minIndex] + " - " + min);
}

//6. Exit the program
