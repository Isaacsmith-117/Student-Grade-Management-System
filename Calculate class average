    public static double AverageCalculate () {
        double sum = 0;
        int amount = 0;
        // assign Sum and the number of students
        for (int i = 0; i < 50; i++) {
            if (Name[i] != null) {
                // Only take the Score if when they have clearly name
                sum = sum + Scores[i];
                amount++;
            }
        }
        if (amount != 0) {
            // Avoid dividing by 0
            return (sum / amount);
        }
        else {
            return 0;
        }
    }
